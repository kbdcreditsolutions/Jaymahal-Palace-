DATABASE_URL="file:./dev.db"

# Admin seed credentials — used once by `prisma db seed`
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Palace Manager"

# Required: 32+ char random secret (openssl rand -hex 32). App refuses to run without it.
JWT_SECRET=""

# Razorpay keys (test or live)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

NEXT_PUBLIC_SITE_URL="http://localhost:3100"

# "true" ONLY for local demos without Razorpay keys — confirms bookings without charging.
DEMO_PAYMENTS="false"
